# Copier vers .env et remplir. Ne jamais committer .env.

# AWS — landing zone S3 (optionnel en local : sans bucket, le spider écrit dans data/landing/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
WATTWATCH_S3_BUCKET=
# MinIO local uniquement (laisser vide pour le vrai S3) — ex. http://localhost:9000
AWS_ENDPOINT_URL=

# Connexion Snowflake pour Airflow (docker-compose) — active wattwatch_load et wattwatch_dbt
# Format URI : snowflake://USER:PASSWORD@/?account=ACCOUNT&warehouse=WATTWATCH_WH&database=WATTWATCH&role=WATTWATCH_TRANSFORM
AIRFLOW_CONN_SNOWFLAKE_WATTWATCH=

# Snowflake (Phase 1+ : COPY INTO via Airflow, transformations dbt)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=WATTWATCH_TRANSFORM
SNOWFLAKE_DATABASE=WATTWATCH
SNOWFLAKE_WAREHOUSE=WATTWATCH_WH
