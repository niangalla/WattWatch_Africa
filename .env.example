# Copier vers .env et remplir. Ne jamais committer .env.

# AWS — landing zone S3 (optionnel en local : sans bucket, le spider écrit dans data/landing/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
# Pas d'underscore : les noms de bucket S3 n'en acceptent pas
WATTWATCH_S3_BUCKET=wattwatch-raw
# MinIO local uniquement (laisser vide pour le vrai S3) — ex. http://minio:9000
AWS_ENDPOINT_URL=

# Connexion Snowflake pour Airflow (docker-compose) — active wattwatch_load et wattwatch_dbt
# Format URI : snowflake://USER:PASSWORD@/?account=ACCOUNT&warehouse=WATTWATCH_WH&database=WATTWATCH&role=WATTWATCH_TRANSFORM
AIRFLOW_CONN_SNOWFLAKE_WATTWATCH=

# Snowflake (Phase 1+ : COPY INTO via Airflow, transformations dbt)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=WATTWATCH_TRANSFORM
SNOWFLAKE_DATABASE=WATTWATCH
SNOWFLAKE_WAREHOUSE=WATTWATCH_WH

# Entrypoint pour initialiser la base Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_FIRSTNAME=
AIRFLOW_ADMIN_LASTNAME=
AIRFLOW_ADMIN_ROLE=Admin
AIRFLOW_ADMIN_EMAIL=

# PostgreSQL (base Airflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
POSTGRES_DB=airflow
# Doit rester cohérent avec les 3 variables ci-dessus — sans elle, Airflow retombe sur SQLite
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:CHANGEME@postgres/airflow

# MinIO (landing zone S3 locale)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
